<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>ffc657ac-401a-4181-8275-25719c811379</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>TeX2Word</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="TeX2WordAddin"/>
  <Description DefaultValue="Convert LaTeX formulas to native Word equations"/>
  <IconUrl DefaultValue="https://wyj-iirtyj.github.io/TeX2WordAddin/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://wyj-iirtyj.github.io/TeX2WordAddin/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://github.com/wyj-IIRtyj/TeX2WordAddin"/>
  <AppDomains>
    <AppDomain>https://wyj-iirtyj.github.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://wyj-iirtyj.github.io/TeX2WordAddin/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://wyj-iirtyj.github.io/TeX2WordAddin/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://wyj-iirtyj.github.io/TeX2WordAddin/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://wyj-iirtyj.github.io/TeX2WordAddin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://github.com/wyj-IIRtyj/TeX2WordAddin"/>
        <bt:Url id="Commands.Url" DefaultValue="https://wyj-iirtyj.github.io/TeX2WordAddin/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://wyj-iirtyj.github.io/TeX2WordAddin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="TeX2Word Ready"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="TeX2Word"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="TeX2Word"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="TeX2Word add-in loaded. Go to HOME tab and click TeX2Word button to start."/>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Convert LaTeX formulas to native Word equations"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
